
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function userIsAdmin(userId) {
        return exists(/databases/$(database)/documents/users/$(userId)) &&
               get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    function isAdmin() {
      return isSignedIn() && userIsAdmin(request.auth.uid);
    }
    
    function isStudent() {
        return isSignedIn() && 
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    // User profiles
    match /users/{userId} {
      // Admins can read any profile, users can only read their own.
      allow get: if isOwner(userId) || isAdmin();
      // Only admins can list all users.
      allow list: if isAdmin();
      // Any authenticated user can create their own profile document.
      allow create: if isOwner(userId);
      // Users can update their own profile, admins can update any.
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete users.
      allow delete: if isAdmin();
    }

    // Program documents
    match /programs/{programId} {
      // Allow public GET for the QR form page. No public list.
      allow get: if true;
      allow list: if isAdmin();
      // Only admins can create, update, or delete programs.
      allow create, update, delete: if isAdmin();
      
      // Attendance subcollection
      match /attendances/{attendanceId} {
        // Anyone can create an attendance record (public form submission).
        allow create: if request.resource.data.programId == programId &&
                         request.resource.data.createdAt == request.time;
        // Only admins can read or delete attendance records.
        allow read, delete: if isAdmin();
        // No updates allowed to preserve record integrity.
        allow update: if false;
      }
    }
    
    // Program form configurations
    match /programConfigs/{programId} {
       // Allow public GET for the QR form page. No public list.
      allow get: if true;
      allow list: if isAdmin();
      // Only admins can create, update, or delete configs.
      allow create, update, delete: if isAdmin();
    }
    
    // Catch-all for other collections - deny by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
