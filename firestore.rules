
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function userIsAdmin(userId) {
        return exists(/databases/$(database)/documents/users/$(userId)) &&
               get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    function isAdmin() {
      return isSignedIn() && userIsAdmin(request.auth.uid);
    }
    
    function isStudent() {
        return isSignedIn() && 
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    // User profiles
    match /users/{userId} {
      // Admins can read any profile, users can only read their own.
      allow get: if isOwner(userId) || isAdmin();
      // Only admins can list all users.
      allow list: if isAdmin();
      // Any authenticated user can create their own profile document.
      allow create: if isOwner(userId);
      // Users can update their own profile, admins can update any.
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete users.
      allow delete: if isAdmin();
    }

    // Program documents
    match /programs/{programId} {
      // Allow public GET for the QR form page.
      // Allow any signed-in user to list programs for their dashboard.
      allow get: if true;
      allow list: if isSignedIn();
      // Only admins can create, update, or delete programs.
      allow create, update, delete: if isAdmin();
      
      // Rules for DIRECT access to the attendance subcollection
      match /attendances/{attendanceId} {
        // Anyone can create OR update an attendance record.
        // This allows for both the initial public check-in and the public check-out.
        allow create, update: if request.resource.data.programId == programId;

        // Students can read their own attendance record, admins can read any.
        allow get: if isAdmin() || (isSignedIn() && request.auth.token.email == attendanceId);
        
        // Only admins can list or delete attendance records.
        allow list, delete: if isAdmin();
      }
    }
    
    // Rule for the 'attendances' collection group query
    match /{path=**}/attendances/{attendanceId} {
      // Allows `collectionGroup('attendances').where('email', '==', user.email)` for students
      // and allows admins to perform any list query.
      allow list: if isAdmin() || (isSignedIn() && request.auth.token.email == resource.data.email);
    }
    
    // Program form configurations
    match /programConfigs/{programId} {
       // Allow public GET for the QR form page. No public list.
      allow get: if true;
      allow list: if isAdmin();
      // Only admins can create, update, or delete configs.
      allow create, update, delete: if isAdmin();
    }

    // Public QR slug to Program ID mapping
    match /qrSlugs/{slug} {
        // Allow public GET to resolve a slug to a program ID. No list.
        allow get: if true;
        allow list: if false;
        // Only admins can manage slug mappings.
        allow write: if isAdmin();
    }
    
    // Catch-all for other collections - deny by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
