
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for reusable logic
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      // Allow user creation if the document ID matches the user's UID.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      // Allow a user to update their own profile, but not change their role.
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
      allow delete: if isOwner(userId);

      // User-specific certificates
      match /certificates/{certificateId} {
        // A user can only view their own certificates.
        allow get, list: if isOwner(userId);
        // Admins can manage all certificates.
        allow read, write: if isAdmin();
      }
    }

    // Program information
    match /programs/{programId} {
      // Any signed-in user can view program details.
      allow get, list: if isSignedIn();
      // Only admins can create, update, or delete programs.
      allow write: if isAdmin();

      // Program-specific registrations
      match /registrations/{registrationId} {
        // Admins can list all registrations for a program.
        allow list: if isAdmin();
        // A user can get their own registration. Admins can also read.
        allow get: if isAdmin() || (resource.data.userId == request.auth.uid);
        // A user can create their own registration.
        allow create: if isOwner(request.resource.data.userId);
        // A user can update (e.g. cancel) their own registration. Admins can also update.
        allow update: if isAdmin() || isOwner(resource.data.userId);
        // Only Admins can delete registrations.
        allow delete: if isAdmin();
      }

      // Program-specific attendance records
      match /attendance/{attendanceId} {
        // Admins can list all attendance for a program.
        allow list: if isAdmin();
        // A user can get their own attendance record. Admins can also read.
        allow get: if isAdmin() || (resource.data.userId == request.auth.uid);
        // A user can create their own attendance record (e.g., by scanning a QR code).
        allow create: if isOwner(request.resource.data.userId);
        // Only admins can modify or delete attendance records.
        allow update, delete: if isAdmin();
      }
    }
  }
}
