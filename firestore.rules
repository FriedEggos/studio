
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // This function is safe because the `get` call for a user on their own
    // document is always allowed by the `isOwner()` check in the /users/{userId} rule.
    function isAdmin() {
        return isSignedIn() &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isStudent() {
        return isSignedIn() && 
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function isCheckoutUpdate() {
      let modifiedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let allowedCheckoutFields = ['checkOutAt', 'checkOutStatus', 'durationMinutes'];
      return modifiedKeys.hasOnly(allowedCheckoutFields);
    }
    
    // User profiles and sub-collections
    match /users/{userId} {
      // Admins can read any profile, users can only read their own.
      allow get: if isOwner(userId) || isAdmin();
      // Only admins can list all users.
      allow list: if isAdmin();
      // Any authenticated user can create their own profile document.
      allow create: if isOwner(userId);
      // Users can update their own profile, admins can update any.
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete users.
      allow delete: if isAdmin();
      
      // Rules for the 'positions' sub-collection
      match /positions/{positionId} {
        // Students can create their own position requests.
        // The verificationStatus must be 'pending' on creation.
        allow create: if isOwner(userId) && request.resource.data.verificationStatus == 'pending';
        // Admins can update any position (to approve/reject), but students cannot.
        allow update: if isAdmin();
        // Admins can delete position records if needed.
        allow delete: if isAdmin();
        // Students can read their own positions, admins can read any.
        allow get, list: if isOwner(userId) || isAdmin();
      }
    }

    // Collection Group query for positions
    match /{path=**}/positions/{positionId} {
      // Allows admins to query across all users' positions sub-collections.
      allow list, get: if isAdmin();
    }

    // Program documents
    match /programs/{programId} {
      // Allow public GET for the QR form page.
      // Allow any signed-in user to list programs for their dashboard.
      allow get: if true;
      allow list: if isSignedIn();
      // Only admins can create, update, or delete programs.
      allow create, update, delete: if isAdmin();
      
      // Rules for DIRECT access to the attendance subcollection
      match /attendances/{attendanceId} {
        // Allow creating a record if the programId matches.
        allow create: if request.resource.data.programId == programId;
        
        // Allow updating a record if it's a valid checkout operation.
        allow update: if isCheckoutUpdate();

        // Students can read their own attendance record, admins can read any.
        allow get: if isAdmin() || (isSignedIn() && request.auth.token.email == attendanceId);
        
        // Only admins can list or delete attendance records.
        allow list, delete: if isAdmin();
      }
    }
    
    // Rule for the 'attendances' collection group query
    match /{path=**}/attendances/{attendanceId} {
      allow list: if isAdmin() || (isSignedIn() && request.auth.token.email == resource.data.email);
    }
    
    // Program form configurations
    match /programConfigs/{programId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Public QR slug to Program ID mapping
    match /qrSlugs/{slug} {
        allow get: if true;
        allow list: if false;
        allow write: if isAdmin();
    }
  }
}
