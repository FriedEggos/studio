
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the JTMK+ system, either a student or an admin.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user entity, matches Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "Full name of the user."
        },
        "role": {
          "type": "string",
          "description": "Role of the user (e.g., student, admin)."
        },
        "course": {
          "type": "string",
          "description": "The course the student is enrolled in."
        },
        "matricId": {
          "type": "string",
          "description": "The student's matriculation ID number."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's phone number."
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "role"
      ]
    },
    "Program": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Program",
      "type": "object",
      "description": "Represents a JTMK program or event.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the program entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the program."
        },
        "description": {
          "type": "string",
          "description": "Description of the program."
        },
        "startDate": {
          "type": "string",
          "description": "Start date and time of the program.",
          "format": "date-time"
        },
        "endDate": {
          "type": "string",
          "description": "End date and time of the program.",
          "format": "date-time"
        },
        "adminId": {
          "type": "string",
          "description": "Reference to User (admin). (Relationship: User 1:N Program)"
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the program's poster image."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "startDate",
        "endDate",
        "adminId"
      ]
    },
    "ActivityEvidence": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ActivityEvidence",
      "type": "object",
      "description": "Represents the evidence of activity submitted by a user for a program.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the evidence record."
        },
        "user_id": {
          "type": "string",
          "description": "Reference to the User who submitted the evidence."
        },
        "studentName": {
          "type": "string",
          "description": "Denormalized name of the student for easy display."
        },
        "program_id": {
          "type": "string",
          "description": "Reference to the Program."
        },
        "programname": {
          "type": "string",
          "description": "The name of the program."
        },
        "submissionDate": {
          "type": "string",
          "description": "Date and time of evidence submission.",
          "format": "date-time"
        },
        "image_url": {
          "type": "string",
          "description": "URL of the uploaded activity evidence (image)."
        },
        "status": {
          "type": "string",
          "description": "Status of the evidence verification.",
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        }
      },
      "required": [
        "id",
        "user_id",
        "studentName",
        "program_id",
        "programname",
        "submissionDate",
        "image_url",
        "status"
      ]
    },
    "Certificate": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Certificate",
      "type": "object",
      "description": "Represents a digital certificate issued to a user for a program.",
      "properties": {
        "cert_id": {
          "type": "string",
          "description": "Unique identifier for the certificate."
        },
        "user_id": {
          "type": "string",
          "description": "Reference to the User who received the certificate."
        },
        "programname": {
          "type": "string",
          "description": "The name of the program for which the certificate was issued."
        },
        "issuedate": {
          "type": "string",
          "description": "The date the certificate was issued.",
          "format": "date-time"
        }
      },
      "required": [
        "cert_id",
        "user_id",
        "programname",
        "issuedate"
      ]
    },
    "Attendance": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Attendance",
      "type": "object",
      "description": "Represents a user's attendance record for a program, captured via QR scan.",
      "properties": {
        "attendance_id": {
          "type": "string",
          "description": "Unique identifier for the attendance record."
        },
        "user_id": {
          "type": "string",
          "description": "Reference to the User."
        },
        "program_id": {
          "type": "string",
          "description": "Reference to the Program."
        },
        "scan_time": {
          "type": "string",
          "description": "The timestamp when the user scanned the QR code.",
          "format": "date-time"
        }
      },
      "required": [
        "attendance_id",
        "user_id",
        "program_id",
        "scan_time"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profiles. Path-based ownership ensures only the user can access their data."
        }
      },
      {
        "path": "/programs/{programId}",
        "definition": {
          "entityName": "Program",
          "schema": {
            "$ref": "#/backend/entities/Program"
          },
          "description": "Stores program details. Includes 'adminId' for authorization, ensuring only the admin who created the program can modify it."
        }
      },
      {
        "path": "/users/{userId}/activity_evidence/{evidenceId}",
        "definition": {
          "entityName": "ActivityEvidence",
          "schema": {
            "$ref": "#/backend/entities/ActivityEvidence"
          },
          "description": "Stores evidence of activity submitted by users for program participation."
        }
      },
      {
        "path": "/users/{userId}/certificates/{certificateId}",
        "definition": {
          "entityName": "Certificate",
          "schema": {
            "$ref": "#/backend/entities/Certificate"
          },
          "description": "Stores certificates issued to users."
        }
      },
      {
        "path": "/users/{userId}/attendance/{attendanceId}",
        "definition": {
          "entityName": "Attendance",
          "schema": {
            "$ref": "#/backend/entities/Attendance"
          },
          "description": "Stores attendance records for users."
        }
      }
    ],
    "reasoning": "The Firestore structure is designed based on user requirements to separate concerns for activity evidence, certificates, and attendance, while maintaining user-owned data patterns. Collections are nested under users to simplify security rules. Denormalized fields like `studentName` and `programname` are used to avoid extra reads in security rules and on the client."
  }
}
