rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check if the requesting user is an admin by reading their role from Firestore.
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for contribution evidence files
    match /contributions/{userId}/{positionId}/{fileName} {
      
      // PUBLIC READ: 
      // Allow anyone with the unguessable URL to read the evidence file.
      // This is necessary for the current app implementation where image URLs are used directly in `<img>` tags by admins for verification.
      allow read;

      // CREATE: 
      // Allow a student to upload their own evidence.
      // File must be an image and under 10MB.
      allow create: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      
      // UPDATE: 
      // Disallow client-side updates to prevent evidence tampering after submission.
      allow update: if false;
      
      // DELETE: 
      // Allow the file's owner (the student) or an admin to delete the file.
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
  }
}
