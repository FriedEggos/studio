rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Rules for user profile pictures
    match /profile-pictures/{userId}/{allPaths=**} {
      // Allow anyone to read profile pictures, which is common for avatars.
      allow read;

      // Allow a user to write to their own profile picture path only.
      // They must be authenticated, the file must be an image, and under 2MB.
      allow write: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.size < 2 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }

    // Rules for contribution evidence
    match /contributions/{userId}/{positionId}/{fileName} {
      // Allow read access to anyone with the link (admins, the user).
      allow read;

      // Allow a user to CREATE their own contribution evidence.
      // They must be authenticated and the owner of the record.
      // File must be an image and under 10MB.
      allow create: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      
      // Do not allow client-side updates to prevent overwriting evidence.
      allow update: if false;
      
      // Allow the user who uploaded it to delete it.
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
