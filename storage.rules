rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Rules for user profile pictures
    match /profile-pictures/{userId}/{allPaths=**} {
      // Allow anyone to read profile pictures, which is common for avatars.
      allow read;

      // Allow a user to write to their own profile picture path only.
      // They must be authenticated, the file must be an image, and under 2MB.
      allow write: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.size < 2 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }
  }
}
